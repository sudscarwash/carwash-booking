rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isUserActive() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isActive == true
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection: /users ---
    match /users/{userId} {
      // Admin can do anything. Active users can read any user (for assignee lists, names, etc.) or specifically their own.
      allow read: if isSignedIn();
      
      // On creation, users can register their profile. We must prevent self-role escalation (must be customer by default).
      allow create: if isSignedIn() && (
        userId == request.auth.uid &&
        incoming().role == "customer" &&
        incoming().isActive == true &&
        incoming().email is string &&
        incoming().name is string
      ) || isAdmin();

      // On update, users can edit their name or email, but cannot change role, isActive status, or businessId (unless Admin).
      allow update: if isSignedIn() && (
        (userId == request.auth.uid && 
         incoming().role == existing().role && 
         incoming().isActive == existing().isActive &&
         (!existing().keys().hasAll(['businessId']) || incoming().businessId == existing().businessId) &&
         incoming().email is string &&
         incoming().name is string
        ) || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // --- Collection: /carWashes ---
    match /carWashes/{carWashId} {
      // Anyone can read active car washes
      allow read: if true;

      // Onboarders (SPECIAL, OWNER, ADMIN) can create.
      allow create: if isSignedIn() && isUserActive() && (
        // Owners or Special can register
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["owner", "special"] &&
          incoming().ownerId == request.auth.uid
        ) || isAdmin()
      );

      // Only the business Owner or Admin can update
      allow update: if isSignedIn() && isUserActive() && (
        (
          existing().ownerId == request.auth.uid &&
          incoming().ownerId == existing().ownerId &&
          incoming().name is string
        ) || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // --- Collection: /bookings ---
    match /bookings/{bookingId} {
      // Customers can read their own bookings.
      // Staff (Owners, Employees, Admins) can read bookings if they manage the car wash.
      allow read: if isSignedIn() && (
        existing().customerId == request.auth.uid ||
        isAdmin() ||
        // Owner check
        (
          exists(/databases/$(database)/documents/carWashes/$(existing().carWashId)) &&
          get(/databases/$(database)/documents/carWashes/$(existing().carWashId)).data.ownerId == request.auth.uid
        ) ||
        // Employee check
        (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "employee" &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == existing().carWashId
        )
      );

      // Customers can book slots
      allow create: if isSignedIn() && isUserActive() && (
        incoming().customerId == request.auth.uid &&
        incoming().status == "pending" &&
        incoming().date is string &&
        incoming().timeSlot is string
      ) || isAdmin();

      // Updates (Rescheduling or Status change)
      allow update: if isSignedIn() && isUserActive() && (
        // Action: Customer cancels or reschedules
        (
          existing().customerId == request.auth.uid &&
          incoming().customerId == existing().customerId &&
          (
            // Customer reschedules
            (incoming().status == "pending" && incoming().date is string && incoming().timeSlot is string) ||
            // Customer cancels
            (incoming().status == "cancelled" && incoming().date == existing().date && incoming().timeSlot == existing().timeSlot)
          )
        ) ||
        // Action: Staff updates status (completed, in_progress, rejected, etc.)
        (
          (
            isAdmin() ||
            // Owner of this wash
            (
              exists(/databases/$(database)/documents/carWashes/$(existing().carWashId)) &&
              get(/databases/$(database)/documents/carWashes/$(existing().carWashId)).data.ownerId == request.auth.uid
            ) ||
            // Employee of this wash
            (
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "employee" &&
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == existing().carWashId
            )
          ) &&
          incoming().customerId == existing().customerId &&
          incoming().date == existing().date &&
          incoming().timeSlot == existing().timeSlot
        )
      );

      allow delete: if isAdmin();
    }

    // --- Collection: /auditLogs ---
    match /auditLogs/{logId} {
      // Only admins can audit logs
      allow read: if isAdmin();
      
      // Active authenticated users can create audit logs
      allow create: if isSignedIn() && isUserActive() && (
        incoming().userId == request.auth.uid &&
        incoming().userEmail == request.auth.token.email &&
        incoming().action is string
      ) || isAdmin();

      allow update, delete: if false;
    }
  }
}
